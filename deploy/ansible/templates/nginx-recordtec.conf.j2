{# Nginx site for recordtec-fe on the public VM (manual install, not Docker)
   Set group_vars e.g. recordtec_backend_host: "10.10.1.4" #}
server {
    listen 80;
    server_name _;

    root /var/www/recordtec-fe;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://{{ recordtec_backend_host }}:{{ recordtec_backend_port | default(8000) }}/;
        proxy_http_version 1.1;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
